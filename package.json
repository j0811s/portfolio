{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check src",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@next/third-parties": "^16.1.0",
    "@types/node": "22.13.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wterm/dom": "^0.1.7",
    "@wterm/just-bash": "^0.1.8",
    "@wterm/react": "^0.1.8",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.12",
    "html-react-parser": "^5.2.11",
    "jotai": "^2.16.0",
    "just-bash": "^2.14.2",
    "kiso.css": "^1.2.2",
    "microcms-js-sdk": "^3.2.0",
    "motion": "^12.39.0",
    "next": "16.2.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "resend": "^6.12.0",
    "schema-dts": "^2.0.0",
    "swr": "^2.3.8",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome format --write",
      "biome lint"
    ],
    "src/**/*.css": [
      "biome format --write",
      "biome lint"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@vitejs/plugin-react": "^5.1.2",
    "dotenv": "^17.4.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "sass": "^1.97.1",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
