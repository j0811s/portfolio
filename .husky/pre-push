#!/bin/sh

# Warn if CHANGELOG.md has not been updated in the commits being pushed

warn=true

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  changed=$(git diff --name-only "$range" 2>/dev/null | grep "^CHANGELOG\.md$")

  if [ -n "$changed" ]; then
    warn=false
    break
  fi
done

if [ "$warn" = "true" ]; then
  echo ""
  echo "🚫 CHANGELOG.md が更新されていません。"
  echo "   /wrap-up を実行してから push してください。"
  echo "   スキップする場合は git push --no-verify を使用してください。"
  echo ""
  exit 1
fi

exit 0
